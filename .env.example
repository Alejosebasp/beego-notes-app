# Beego Notes App - Environment Configuration Example

# Development / Production settings
BEEGO_RUNMODE=prod

# Database path (Volume mapped in Docker)
DB_PATH=/data/notes.db

# HTTPS Settings
HTTPS_PORT=8443
HTTPS_CERT=conf/cert.pem
HTTPS_KEY=conf/key.pem

# HTTP Port (Disabled by default if EnableHTTP is false in app.conf)
HTTP_PORT=8080
